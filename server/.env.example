JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

SUPERADMIN_USERNAME=""
SUPERADMIN_PASSWORD=""
SUPERADMIN_FULL_NAME=""

TELEGRAM_BOT_TOKEN=""
