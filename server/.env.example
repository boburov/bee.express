DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/bee_express"

# Generate strong random values for production, e.g.: openssl rand -base64 48
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# In production the seed REFUSES weak/default passwords (<12 chars or known
# defaults like "ChangeMe!2026"). Use a strong unique password.
SUPERADMIN_USERNAME=""
SUPERADMIN_PASSWORD=""
SUPERADMIN_FULL_NAME=""

TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME="BeeExpressBot"

PORT=60000
NODE_ENV="development"
OTP_TTL_SECONDS=120
OTP_MAX_ATTEMPTS=5

# Comma-separated CORS allow-list (panel origins). REQUIRED in production for
# any origin beyond the always-allowed defaults baked into src/common/cors.ts
# (currently: https://bee-express.vercel.app). Dev reflects any origin when
# unset; in production the env list is merged with those defaults.
#   CORS_ORIGINS=https://admin.example.uz,https://app.example.uz,https://seller.example.uz,https://courier.example.uz
CORS_ORIGINS=""

# Uploads — when CLOUDFLARE_R2_* is unset, images are stored on local disk
# (UPLOADS_DIR, default <server>/uploads-data) and served at
# <UPLOADS_PUBLIC_BASE_URL>/uploads-static/... UPLOADS_PUBLIC_BASE_URL must be
# this API's PUBLIC origin. Default: http://localhost:<PORT>.
UPLOADS_DIR=""
UPLOADS_PUBLIC_BASE_URL=""

REDIS_URL="redis://127.0.0.1:6379"

# Cloudflare R2 (S3-compatible object storage) — product/store images.
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_BUCKET=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
# Public CDN base URL — bucket "Public access" yoki custom domain.
CLOUDFLARE_R2_PUBLIC_URL=""
