// BeeExpress — initial schema (auth + role domain)
// Phone numbers stored as BigInt in the form 993411786 (country code +998 implicit).
// Super admin lives in its own table with login + bcrypt hash.
// All other roles (ADMIN included as `isSystem: true`) live in `Role` and are dynamic.
// Domain models (Store, Product, Order, Category, ...) will be added in the next phase.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ─────────────────────────────────────────────────────────────
// Roles
// ─────────────────────────────────────────────────────────────

model Role {
  id          String  @id @default(cuid())
  slug        String  @unique // machine-readable: "admin", "seller", "courier", "customer", or dynamic
  name        String // human-readable label
  description String? @db.Text
  isSystem    Boolean @default(false) // true for ADMIN; system roles cannot be deleted
  permissions Json    @default("[]") // array of permission slugs e.g. ["user.read", "order.write"]

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isSystem])
}

// ─────────────────────────────────────────────────────────────
// Users — anyone authenticated via phone+Telegram OTP
// (customers, sellers, couriers, admins — distinguished by Role)
// ─────────────────────────────────────────────────────────────

model User {
  id String @id @default(cuid())

  // Phone: 993411786 (no +998 prefix), stored as numeric
  phone BigInt @unique

  // Telegram link — set once user shares contact via /start in the bot
  telegramId       BigInt?   @unique
  telegramUsername String?
  telegramFirst    String?
  telegramLast     String?
  telegramLinkedAt DateTime?

  // Optional profile
  firstName String?
  lastName  String?
  avatarUrl String?

  // Role (nullable: a user may register via TG before being assigned any role)
  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)

  // Free-form profile data — varies by role (seller docs, courier vehicle, etc.)
  // Keeps the system "fully dynamic" without rigid per-role tables at the auth layer.
  profile Json?

  isBlocked   Boolean   @default(false)
  blockedAt   DateTime?
  blockReason String?   @db.Text

  // Auth artifacts
  otps     Otp[]
  sessions Session[]

  // Catalog back-relations
  stores          Store[]
  createdProducts Product[] @relation("ProductCreator")

  // Marketplace v1 back-relations
  uploads         UploadedFile[]
  reviews         Review[]
  productRequests ProductRequest[]
  notifications   Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleId])
  @@index([isBlocked])
}

// ─────────────────────────────────────────────────────────────
// Super Admin — separate from User. Login + password, no phone OTP.
// Seeded from env on first boot; password is re-hashable from the panel.
// ─────────────────────────────────────────────────────────────

model SuperAdmin {
  id        String    @id @default(cuid())
  username  String    @unique
  password  String // bcrypt hash
  fullName  String?
  isActive  Boolean   @default(true)
  lastLogin DateTime?

  sessions SuperAdminSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// One-time passwords delivered via Telegram bot
// ─────────────────────────────────────────────────────────────

enum OtpPurpose {
  LOGIN
  REGISTER
  PHONE_CHANGE
}

model Otp {
  id String @id @default(cuid())

  // userId is nullable: during first-time login we may not have a User yet
  // (the bot may have stored phone+telegramId without an explicit User row).
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone      BigInt
  code       String // 6-digit, stored as string to preserve leading zeros
  purpose    OtpPurpose @default(LOGIN)
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int        @default(0)
  ip         String?
  userAgent  String?    @db.Text

  createdAt DateTime @default(now())

  @@index([phone, purpose])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────
// Sessions (refresh tokens) — both for normal users and SuperAdmin
// ─────────────────────────────────────────────────────────────

model Session {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique @db.VarChar(512) // JWT refresh tokens are long
  userAgent String?   @db.Text
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model SuperAdminSession {
  id           String     @id @default(cuid())
  superAdminId String
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)
  token        String     @unique @db.VarChar(512) // JWT refresh tokens are long
  userAgent    String?    @db.Text
  ip           String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime   @default(now())

  @@index([superAdminId])
}

// ─────────────────────────────────────────────────────────────
// Audit log — every meaningful action (TZ §24 xavfsizlik)
// ─────────────────────────────────────────────────────────────

enum ActorType {
  USER
  SUPER_ADMIN
  SYSTEM
}

model AuditLog {
  id String @id @default(cuid())

  actorType ActorType
  actorId   String? // userId or superAdminId

  action     String // e.g. "auth.login", "role.create", "user.block"
  resource   String? // e.g. "user", "role"
  resourceId String?

  metadata  Json? // arbitrary context
  ip        String?
  userAgent String? @db.Text

  createdAt DateTime @default(now())

  @@index([actorType, actorId])
  @@index([action])
  @@index([createdAt])
}

// ═════════════════════════════════════════════════════════════
// Catalog v1 — shared catalog (master Product → many SellerOffer),
// dynamic per-category Attributes, ProductVariant (color/size/RAM).
// See docs/catalog-v1.md for the spec this implements.
// ═════════════════════════════════════════════════════════════

// ─── Category tree ───
//
// `type` drives delivery behavior. FOOD requires geo-aware ordering (nearest
// store), distance-based delivery fee and an ETA window. MARKETPLACE products
// (electronics, construction, household, …) still know the store location but
// don't filter by radius and the per-km fee can be different per category.
// Category-level defaults can be overridden by Store.deliveryRadiusKm etc.

enum CategoryType {
  FOOD
  MARKETPLACE
}

model Category {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String
  nameRu    String?
  parentId  String?
  parent    Category?    @relation("CategoryTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  Category[]   @relation("CategoryTree")
  iconUrl   String?
  imageUrl  String?
  sortOrder Int          @default(0)
  isActive  Boolean      @default(true)
  type      CategoryType @default(MARKETPLACE)

  // Delivery defaults — used when Store-level overrides are null.
  // `deliveryBaseFee` and `deliveryPerKmFee` are stored as Decimal(12,2) so we
  // can do server-side fee math without floating-point drift.
  deliveryRadiusKm     Int?
  deliveryBaseFee      Decimal? @db.Decimal(12, 2)
  deliveryPerKmFee     Decimal? @db.Decimal(12, 2)
  deliveryEtaMinMinutes Int?
  deliveryEtaMaxMinutes Int?
  minOrderAmount       Decimal? @db.Decimal(12, 2)

  attributes CategoryAttribute[]
  products   Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([isActive])
  @@index([type, isActive])
}

// ─── Brand ───

model Brand {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  logoUrl   String?
  isActive  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ─── Attribute (dynamic, per-category) ───

enum AttributeType {
  SELECT
  MULTI
  NUMBER
  TEXT
  BOOL
}

model Attribute {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  nameRu       String?
  type         AttributeType
  unit         String?
  isFilterable Boolean       @default(true)

  values         AttributeValue[]
  categories     CategoryAttribute[]
  productValues  ProductAttributeValue[]
  variantOptions VariantOption[]

  createdAt DateTime @default(now())
}

model AttributeValue {
  id          String    @id @default(cuid())
  attributeId String
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String
  label       String?
  hexColor    String?
  sortOrder   Int       @default(0)

  productValues  ProductAttributeValue[]
  variantOptions VariantOption[]

  @@unique([attributeId, value])
  @@index([attributeId])
}

model CategoryAttribute {
  categoryId  String
  attributeId String
  isRequired  Boolean @default(false)
  sortOrder   Int     @default(0)

  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([categoryId, attributeId])
  @@index([attributeId])
}

// ─── Product (master, seller-agnostic) ───

enum ProductStatus {
  DRAFT
  PENDING
  ACTIVE
  REJECTED
  ARCHIVED
}

model Product {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  titleRu     String?
  description String?       @db.Text
  categoryId  String
  brandId     String?
  status      ProductStatus @default(PENDING)
  createdById String

  category  Category @relation(fields: [categoryId], references: [id])
  brand     Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  createdBy User     @relation("ProductCreator", fields: [createdById], references: [id])

  attributeValues ProductAttributeValue[]
  variants        ProductVariant[]
  images          ProductImage[]
  reviews         Review[]
  requests        ProductRequest[]

  rejectionReason String?   @db.Text
  publishedAt     DateTime?

  // Cached aggregates — recomputed on review write / order delivery.
  ratingAvg   Decimal @default(0) @db.Decimal(3, 2)
  ratingCount Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, status])
  @@index([brandId])
  @@index([status])
  @@index([createdById])
}

// Product × Attribute → Value (SELECT/MULTI: valueId; NUMBER/TEXT/BOOL: rawValue)
model ProductAttributeValue {
  id          String  @id @default(cuid())
  productId   String
  attributeId String
  valueId     String?
  rawValue    String?

  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute Attribute       @relation(fields: [attributeId], references: [id])
  value     AttributeValue? @relation(fields: [valueId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([attributeId, valueId])
  @@index([attributeId, rawValue])
}

// ─── Variant (SKU) ───

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  sku       String? @unique
  title     String?
  isDefault Boolean @default(false)

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  options VariantOption[]
  offers  SellerOffer[]
  images  ProductImage[]

  createdAt DateTime @default(now())

  @@index([productId])
}

model VariantOption {
  variantId   String
  attributeId String
  valueId     String

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute Attribute      @relation(fields: [attributeId], references: [id])
  value     AttributeValue @relation(fields: [valueId], references: [id])

  @@id([variantId, attributeId])
  @@index([attributeId, valueId])
}

// ─── Image ───

model ProductImage {
  id        String  @id @default(cuid())
  productId String?
  variantId String?
  url       String
  alt       String?
  sortOrder Int     @default(0)

  product Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([variantId])
}

// ─── Store (Seller's shop) ───

enum StoreStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CLOSED
}

model Store {
  id          String      @id @default(cuid())
  ownerId     String
  slug        String      @unique
  name        String
  description String?     @db.Text
  logoUrl     String?
  bannerUrl   String?
  status      StoreStatus @default(PENDING)

  // KYC
  inn       String?
  legalName String?

  // Contact + presentation
  phone   String?
  address String? @db.Text

  // Geo — used by nearest-seller queries (FOOD) and distance fee math.
  // Stored as Decimal to keep precision; nullable until the seller picks a point.
  // Bounding-box pre-filter then haversine refine: see GeoService.
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)

  // Delivery — when null, category defaults are used.
  deliveryRadiusKm  Int?
  deliveryBaseFee   Decimal? @db.Decimal(12, 2)
  deliveryPerKmFee  Decimal? @db.Decimal(12, 2)
  deliveryEtaMinutes Int?
  minOrderAmount    Decimal? @db.Decimal(12, 2)

  // Operating state — `isOpen` is the manual "stop accepting orders" flag.
  // `openingHours` is a weekly schedule (Json) consulted by isStoreOpenNow().
  isOpen       Boolean @default(true)
  openingHours Json?

  rejectionReason String?   @db.Text
  approvedAt      DateTime?

  owner    User             @relation(fields: [ownerId], references: [id])
  offers   SellerOffer[]
  reviews  Review[]
  requests ProductRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([status])
  // Bounding-box prefilter index — paired with a runtime haversine refine
  // for accurate distance. MariaDB doesn't have native geospatial in our
  // setup so two cheap composite indexes beat a single 2D index here.
  @@index([latitude, longitude])
  @@index([status, isOpen])
}

// ─── Seller Offer (Store × Variant) ───

enum OfferCondition {
  NEW
  USED
  REFURBISHED
}

model SellerOffer {
  id           String         @id @default(cuid())
  storeId      String
  variantId    String
  price        Decimal        @db.Decimal(12, 2)
  oldPrice     Decimal?       @db.Decimal(12, 2)
  stock        Int            @default(0)
  condition    OfferCondition @default(NEW)
  isActive     Boolean        @default(true)
  deliveryDays Int?

  store   Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, variantId])
  @@index([variantId, isActive, price])
  @@index([storeId])
}

// ═════════════════════════════════════════════════════════════
// Marketplace v1 additions — uploads, reviews, product requests.
// ═════════════════════════════════════════════════════════════

// ─── UploadedFile — tracks every R2 object we issue a key for ───
//
// Lifecycle:
//   1. Client calls POST /uploads/presign → server picks an R2 key, signs a
//      PUT URL, persists the row in PENDING state.
//   2. Client PUTs the file directly to R2 (no traffic through our box).
//   3. Client calls POST /uploads/:id/complete → server verifies the object
//      exists in R2, flips status to READY, returns the CDN URL.
//   4. The caller (product create, store edit, …) attaches the upload.id
//      to its entity. Orphan rows in PENDING are GC'd by a cron later.

enum UploadStatus {
  PENDING
  READY
  FAILED
}

enum UploadPurpose {
  PRODUCT_IMAGE
  STORE_LOGO
  STORE_BANNER
  USER_AVATAR
  REVIEW_IMAGE
  OTHER
}

model UploadedFile {
  id         String        @id @default(cuid())
  // R2 object key (bucket-relative path). UNIQUE so we never reuse a key.
  key        String        @unique
  // Public URL (CDN or R2 public bucket). Filled when status → READY.
  url        String?
  mimeType   String
  // Size in bytes. Server-validates against per-purpose limits.
  size       Int           @default(0)
  status     UploadStatus  @default(PENDING)
  purpose    UploadPurpose

  // Soft link to the entity the upload belongs to (resolved at attach time).
  entityType String?
  entityId   String?

  uploaderId String
  uploader   User   @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  readyAt   DateTime?

  @@index([uploaderId])
  @@index([entityType, entityId])
  @@index([status, createdAt])
}

// ─── Review — verified-buyer ratings ───
//
// Only buyers whose Order was DELIVERED can leave a review (enforced in
// ReviewsService.create when the orders module ships; until then a
// placeholder gate accepts any authenticated user but the row carries
// `verified=false`).

model Review {
  id        String   @id @default(cuid())
  productId String
  storeId   String
  userId    String
  // orderId is set when verification succeeds — kept nullable so the row can
  // exist before orders ship.
  orderId   String?

  rating    Int      // 1..5 — checked at the service layer
  text      String?  @db.Text
  imageUrls Json     @default("[]") // array of CDN URLs (capped at 5)

  // Verified = bought-and-delivered. Unverified reviews can still be shown
  // but get a different badge in the UI.
  verified  Boolean  @default(false)
  isVisible Boolean  @default(true) // moderation flag — admin can hide

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, userId, orderId])
  @@index([productId, isVisible, createdAt])
  @@index([storeId, isVisible])
  @@index([userId])
}

// ─── ProductRequest — "I need this" pings from buyers ───
//
// Created when a buyer hits "Notify me when restocked" on an unavailable
// product. De-duplicated per (productId, userId) — re-clicking refreshes
// the timestamp and adds an extra `count`.

enum ProductRequestStatus {
  NEW
  NOTIFIED
  FULFILLED
  DISMISSED
}

model ProductRequest {
  id        String               @id @default(cuid())
  productId String
  // The store the buyer is interested in; null means "any seller".
  storeId   String?
  userId    String
  note      String?              @db.Text
  count     Int                  @default(1)
  status    ProductRequestStatus @default(NEW)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime  @default(now())
  notifiedAt   DateTime?
  fulfilledAt  DateTime?

  @@unique([productId, userId, storeId])
  @@index([productId, status])
  @@index([storeId, status])
  @@index([userId])
}

// ═════════════════════════════════════════════════════════════
// Notifications v1 — realtime + persisted.
//
// Sent by SuperAdmin (or SYSTEM events later), delivered to:
//   - a single user, OR
//   - every user holding a given role slug ("seller", "courier", …), OR
//   - everyone (broadcast).
//
// A Notification row is created per **recipient** so we keep simple read
// state and per-user history. Broadcasts fan-out to N rows on send — fine
// up to ~100k users, beyond that we move to a `NotificationBroadcast` +
// per-user `Read` join. Optimise when the metric hurts, not before.
// ═════════════════════════════════════════════════════════════

enum NotificationType {
  INFO       // neutral
  SUCCESS    // positive (order accepted, payout sent)
  WARNING    // attention (low stock, KYC issue)
  DANGER     // urgent (account blocked, fraud alert)
  ANNOUNCE   // marketing / system-wide
}

enum NotificationChannel {
  IN_APP    // pushed via Socket.IO + persisted (default)
  TELEGRAM  // queued for the bot worker (optional add-on)
}

enum NotificationSenderType {
  SUPER_ADMIN
  USER
  SYSTEM
}

model Notification {
  id            String           @id @default(cuid())
  recipientId   String
  recipient     User             @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  // Who sent this. For SUPER_ADMIN/USER, `senderId` holds the actor id;
  // SYSTEM events leave it null.
  senderType    NotificationSenderType
  senderId      String?

  title         String
  body          String?          @db.Text
  type          NotificationType @default(INFO)

  // Free-form payload for click-through actions: { orderId, link, ... }.
  data          Json?

  // Whether the in-app socket push succeeded at least once (otherwise the
  // client will pick it up on next /notifications/mine fetch).
  delivered     Boolean          @default(false)
  // Optional Telegram bot fan-out — set when the bot has actually sent it.
  telegramSent  Boolean          @default(false)

  readAt        DateTime?

  // When the same logical message is sent to many users, share a groupId so
  // we can show "Sent to 230 sellers" in the admin history.
  groupId       String?

  createdAt     DateTime         @default(now())

  @@index([recipientId, readAt])
  @@index([recipientId, createdAt])
  @@index([groupId])
}
